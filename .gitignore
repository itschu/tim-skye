cache/exchange-rates.php

# Uploads: ignore all uploaded files but keep `.htaccess` and `.gitkeep` in any subfolder
# Ignore everything under uploads recursively
/uploads/**
# Ensure the uploads directory and its subdirectories are not permanently excluded
!/uploads/
!/uploads/**/
# Re-include any .htaccess and .gitkeep files located anywhere under uploads
!/uploads/**/.htaccess
!/uploads/**/.gitkeep

# Traycer artifacts (local tooling)
.traycer/

