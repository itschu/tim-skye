# Deny execution of PHP files
<IfModule mod_php5.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

# Allow only image file types for direct access
<FilesMatch "\.(?i:jpg|jpeg|png|gif|bmp|webp)$">
    Require all granted
</FilesMatch>

# Deny access to all other file types
<FilesMatch "\.(?i:php|php3|php4|php5|phtml|pl|py|jsp|asp|sh|cgi|exe|dll)$">
    Require all denied
</FilesMatch>